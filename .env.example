# Formspree のフォームID（お問い合わせページ用）
# https://formspree.io でアカウント作成後、フォームを作成してIDを取得
NEXT_PUBLIC_FORMSPREE_ID=YOUR_FORM_ID

# お問い合わせフォーム（サーバー側転送用。NEXT_PUBLIC_ は不要になりました）
FORMSPREE_ID=YOUR_FORM_ID

# 管理画面（/admin）のパスワード。未設定なら管理機能は無効
ADMIN_PASSWORD=

# 本番（Vercel）でお知らせを保存する場合: GitHubにcommitして自動デプロイで反映
# GITHUB_REPO は owner/repo 形式
GITHUB_TOKEN=
GITHUB_REPO=chisato-0103/ait-transit
